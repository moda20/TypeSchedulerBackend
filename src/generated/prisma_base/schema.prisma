generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma_base"
  binaryTargets = ["linux-arm64-openssl-1.1.x", "darwin-arm64", "debian-openssl-1.1.x", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("BASE_DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user {
  id         Int      @id @unique(map: "id") @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)
  username   String   @db.VarChar(255)
  password   String   @db.VarChar(255)

  configChanges appConfigAudit[]
  apiKeys       apiKeys[]
}

model apiKeys {
  id          String    @id @unique(map: "id") @default(nanoid(10)) @db.VarChar(255)
  name        String    @db.VarChar(255)
  key         String    @unique @db.VarChar(255)
  createdBy   user      @relation(fields: [createdById], references: [id])
  createdById Int
  lastUsedAt  DateTime?
  created_at  DateTime  @default(now()) @db.DateTime(0)
  updated_at  DateTime  @default(now()) @db.DateTime(0)

  @@unique([createdById, name], map: "apiKeys_createdById_name_key")
}

model appConfig {
  id           Int      @id @unique(map: "id") @default(autoincrement())
  key          String   @unique @db.VarChar(255)
  value        String?  @db.LongText
  is_encrypted Boolean  @default(false)
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @db.DateTime(0)

  appConfigAudit appConfigAudit[]
}

model appConfigAudit {
  id            Int        @id @unique(map: "id") @default(autoincrement())
  config        appConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  configId      Int?
  oldValue      String?    @db.LongText
  newValue      String?    @db.LongText
  changedBy     user       @relation(fields: [changedUserId], references: [id], map: "config_changed_by_user")
  changedUserId Int
  created_at    DateTime   @default(now()) @db.DateTime(0)
  updated_at    DateTime   @default(now()) @db.DateTime(0)
}

model notificationServices {
  id            Int            @id @unique(map: "id") @default(autoincrement())
  name          String         @unique @db.VarChar(255)
  description   String         @db.VarChar(255)
  entryPoint    String         @db.VarChar(255)
  image         String?        @db.VarChar(255)
  created_at    DateTime       @default(now()) @db.DateTime(0)
  updated_at    DateTime       @default(now()) @db.DateTime(0)
  notifications notification[]
}

model notification {
  id         Int                   @id @unique(map: "id") @default(autoincrement())
  message    String?               @db.LongText
  data       Json?                 @db.Json
  service    notificationServices? @relation(fields: [service_id], references: [id], map: "notification_service")
  service_id Int?
  job_log_id String?               @db.VarChar(255)
  is_sent    Boolean               @default(false)
  created_at DateTime              @default(now()) @db.DateTime(0)
  updated_at DateTime              @default(now()) @db.DateTime(0)
}
