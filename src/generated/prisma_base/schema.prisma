generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma_base"
  binaryTargets = ["linux-arm64-openssl-1.1.x", "darwin-arm64", "debian-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("BASE_DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user {
  id         Int      @id @unique(map: "id") @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)
  username   String   @db.VarChar(255)
  password   String   @db.VarChar(255)

  configChanges appConfigAudit[]
}

model appConfig {
  id           Int      @id @unique(map: "id") @default(autoincrement())
  key          String   @unique @db.VarChar(255)
  value        String?  @db.LongText
  is_encrypted Boolean  @default(false)
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @db.DateTime(0)

  appConfigAudit appConfigAudit[]
}

model appConfigAudit {
  id            Int        @id @unique(map: "id") @default(autoincrement())
  config        appConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  configId      Int?
  oldValue      String?    @db.LongText
  newValue      String?    @db.LongText
  changedBy     user       @relation(fields: [changedUserId], references: [id], map: "config_changed_by_user")
  changedUserId Int
  created_at    DateTime   @default(now()) @db.DateTime(0)
  updated_at    DateTime   @default(now()) @db.DateTime(0)
}
